{
	"name": "elysia-porto",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"command": "bun run command.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"prepare": "lefthook install || true"
	},
	"dependencies": {
		"@elysiajs/swagger": "^1.3.1",
		"@faker-js/faker": "^9.3.0",
		"better-auth": "^1.6.20",
		"commander": "^12.1.0",
		"drizzle-orm": "^0.36.4",
		"elysia": "^1.2.10",
		"ioredis": "^5.11.1",
		"pino": "^9.5.0",
		"pino-mongodb": "^4.3.0",
		"pino-pretty": "^13.0.0",
		"postgres": "^3.4.5",
		"uuidv7": "^1.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "^1.1.14",
		"drizzle-kit": "^0.29.1",
		"lefthook": "^1.10.1",
		"typescript": "^5.7.2",
		"vitepress": "^1.6.4"
	}
}
